# MobileFlow Agent Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.
#
# All keys use the MOBILEFLOW_ prefix.
# These override values from config/default.json.

# ── Network ──
# MOBILEFLOW_HOST=0.0.0.0
# MOBILEFLOW_PORT=9600

# ── Connection Mode (lan / relay / tunnel) ──
# MOBILEFLOW_CONNECTION_MODE=lan

# ── Relay Server ──
# MOBILEFLOW_RELAY_URL=wss://relay.example.com

# ── Tunnel Mode ──
# MOBILEFLOW_TUNNEL_BEARER_TOKEN=your-secret-token
# MOBILEFLOW_TUNNEL_TLS_CERT=/path/to/cert.pem
# MOBILEFLOW_TUNNEL_TLS_KEY=/path/to/key.pem

# ── Default CLI Agent ──
# MOBILEFLOW_DEFAULT_CLI=claude-code
