# Tunnel mode test configuration
# Usage: copy these values to .env or set as environment variables before starting Agent
#
# PowerShell:
#   $env:MOBILEFLOW_CONNECTION_MODE="tunnel"
#   $env:MOBILEFLOW_TUNNEL_BEARER_TOKEN="your-secret-token-here"
#   $env:MOBILEFLOW_TUNNEL_TLS_CERT="<path-to-agent>/tunnel_cert.pem"
#   $env:MOBILEFLOW_TUNNEL_TLS_KEY="<path-to-agent>/tunnel_key.pem"
#   python -m mobileflow_agent
#
# To switch back to LAN mode:
#   Remove-Item Env:MOBILEFLOW_CONNECTION_MODE

MOBILEFLOW_CONNECTION_MODE=tunnel
MOBILEFLOW_TUNNEL_BEARER_TOKEN=your-secret-token-here
MOBILEFLOW_TUNNEL_TLS_CERT=<path-to-agent>/tunnel_cert.pem
MOBILEFLOW_TUNNEL_TLS_KEY=<path-to-agent>/tunnel_key.pem
